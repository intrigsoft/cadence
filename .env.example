# Cadence environment (all optional for the standalone app).

# --- Phase 2 / DioscHub assistant integration ---

# HMAC secret used to sign + verify BYOA artifacts. Set a strong value in any
# real deployment; the default is an insecure dev fallback. The minting process
# and the verifying process must share this value.
CADENCE_ARTIFACT_SECRET=change-me-in-production

# Enables the DEV-ONLY headless artifact mint route (POST /api/v1/dev/artifact).
# Only honored when running the dev server. NEVER set this in production.
# CADENCE_DEV_ARTIFACT=1

# --- Consumed by the MCP relay (mcp/), not the app ---
# CADENCE_API_URL=http://localhost:5173
# CADENCE_ARTIFACT=<a BYOA artifact token>
